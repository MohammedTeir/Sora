rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each authenticated user may only read and write their own data subtree.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Shared lists: any authenticated user may read; only the creator may write or delete.
    match /shared_lists/{listId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.creatorId == request.auth.uid
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['importCount']));
      allow delete: if request.auth != null && resource.data.creatorId == request.auth.uid;
    }
  }
}
